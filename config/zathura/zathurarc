set notification-error-bg       "#ebdbb2"   
set notification-error-fg       "#c14a4a"   
set notification-warning-bg     "#ebdbb2"   
set notification-warning-fg     "#b47109"   
set notification-bg             "#ebdbb2"   
set notification-fg             "#654735"   

set completion-bg               "#ebdbb2"   
set completion-fg               "#654735"   
set completion-group-bg         "#ebdbb2"
set completion-group-fg         "#ebdbb2"   
set completion-highlight-bg     "#45707a"   
set completion-highlight-fg     "#ebdbb2"   

set index-bg                    "#ebdbb2"
set index-fg                    "#f2e5bc"   
set index-active-bg             "#f2e5bc"
set index-active-fg             "#ebdbb2"

set inputbar-bg                 "#ebdbb2"
set inputbar-fg                 "#654735"

set statusbar-bg                "#ebdbb2"
set statusbar-fg                "#654735"

set highlight-color             "#6c782e"
set highlight-active-color      "#4c7a5d"    

set default-bg                  "#ebdbb2"
set default-fg                  "#654735"
set render-loading              "true"
set render-loading-bg           "#ebdbb2"
set render-loading-fg           "#654735"

set recolor-lightcolor          "#ebdbb2"
set recolor-darkcolor           "#654735"
set recolor                     "true"

set pages-per-row 1

map J zoom out
map K zoom in
unmap f
map f toggle_fullscreen
map [fullscreen] f toggle_fullscreen
map r reload

map b toggle_page_mode 

unmap u
unmap d
map u scroll full-up
map d scroll full-down

set scroll-page-aware "true"
set scroll-full-overlap 0.01
set scroll-step 100

set zoom-min 5
set guioptions ""

set smooth-scroll "true"
